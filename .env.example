# Database (Railway auto-injects DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/material_audit?schema=public"

# Admin password hash (generate with: npx bcryptjs hash "your-password")
ADMIN_PASSWORD_HASH="$2a$10$..."

# Session encryption secret (32+ character random string)
SESSION_SECRET="your-random-secret-at-least-32-characters-long"

# File storage path (Railway volume mount point)
STORAGE_PATH="./uploads"

# Public app URL (for image serving)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
